#!/usr/bin/env bash
#
# Blocks the two ways a key reaches a public repo: committing the file that holds it,
# or pasting it into source. Enable once per clone:
#
#   git config core.hooksPath .githooks
#
# (bin/setup.sh does this for you.)

set -e

staged=()
# Git C-quotes non-ASCII paths by default, so line-oriented output can hide a
# forbidden basename behind quotes. NUL-delimited names preserve every path byte.
while IFS= read -r -d '' f; do
    staged+=("$f")
done < <(git diff --cached --name-only --diff-filter=ACM -z)
[ "${#staged[@]}" -eq 0 ] && exit 0

fail() {
    echo ""
    echo "  ✋ pre-commit blocked this commit."
    echo "     $1"
    echo ""
    echo "     If you are certain it is a false positive:  git commit --no-verify"
    echo "     Do not do that for anything that looks like a real key."
    echo ""
    exit 1
}

# 1. Files that must never be committed.
for f in "${staged[@]}"; do
    case "$f" in
        .env.example|*/.env.example)
            continue
            ;;
        .env|.env.*|*/.env|*/.env.*|*/application-local.yml|*/application-local.yaml|*.pem|*.key|*.jks|*.p12)
            fail "'$f' holds secrets. It should be gitignored — check .gitignore."
            ;;
    esac
done

# 2. Secret-shaped strings among the ADDED lines of the staged diff.
added=$(git diff --cached -U0 | grep '^+' | grep -v '^+++' || true)
[ -z "$added" ] && exit 0

# Placeholders that make up the credential candidate itself are not credentials.
# A placeholder word elsewhere on the same line must not excuse a real candidate.
is_placeholder() {
    value=$1
    case "$value" in
        change-me*|not-needed|YOUR_*|example|example-*|'${'*'}'|\<*\>)
            return 0
            ;;
    esac
    printf '%s\n' "$value" | grep -Eq '^x{4,}$'
}

credential_value() {
    match=$1
    case "$match" in
        serviceKey=*) printf '%s\n' "${match#serviceKey=}" ;;
        sk-*) printf '%s\n' "${match#sk-}" ;;
        gh[pousr]_*) printf '%s\n' "${match#????}" ;;
        AIza*) printf '%s\n' "${match#AIza}" ;;
        *)
            printf '%s\n' "$match" | sed -E \
                "s/^(API_KEY|SERVICE_KEY|SECRET|TOKEN|PASSWORD)[[:space:]]*[:=][[:space:]]*['\"]?//"
            ;;
    esac
}

# NOTE: this loop must NOT be fed by a pipe. `... | while` runs in a subshell, so `fail`'s
# `exit 1` would kill only the subshell and the hook would exit 0 — reporting the secret
# and committing it anyway. A here-document keeps the loop in the current shell.
while IFS= read -r pattern; do
    [ -z "$pattern" ] && continue
    matches=$(printf '%s\n' "$added" | grep -Eo "$pattern" || true)
    [ -z "$matches" ] && continue

    real=
    while IFS= read -r match; do
        value=$(credential_value "$match")
        if ! is_placeholder "$value"; then
            real=1
            break
        fi
    done <<MATCHES
$matches
MATCHES
    [ -n "$real" ] && fail "A staged line looks like a real credential. Pattern: $pattern"
done <<'PATTERNS'
serviceKey=[A-Za-z0-9%+/=]{20,}
sk-[A-Za-z0-9_-]{20,}
gh[pousr]_[A-Za-z0-9]{30,}
AIza[A-Za-z0-9_-]{30,}
(API_KEY|SERVICE_KEY|SECRET|TOKEN|PASSWORD)[[:space:]]*[:=][[:space:]]*['"]?[A-Za-z0-9+/_-]{24,}
PATTERNS

exit 0
