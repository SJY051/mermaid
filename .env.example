# =================================================================
#  mermAid — environment template
#
#  1. Copy this file:   cp .env.example .env
#  2. Fill in the real values.
#  3. NEVER commit .env — it is gitignored, and this repo is PUBLIC.
#
#  The backend reads these via `docker compose` and Spring's
#  `${ENV_VAR}` placeholder syntax in application.yml.
# =================================================================

# --- Database (docker compose) ---
MARIADB_DATABASE=mermaid
MARIADB_USER=mermaid
MARIADB_PASSWORD=change-me-locally
MARIADB_ROOT_PASSWORD=change-me-locally-too

# --- LLM provider (OpenAI-compatible endpoint) ---
# We talk to any OpenAI-compatible base URL. Examples:
#   https://api.openai.com/v1
#   https://opencode.ai/zen/go/v1
#
# Pick a model that honours `response_format: json_schema` — verified 2026-07-10:
#   glm-5.2, kimi-k2.6   → strict schema respected (oneOf/$defs/const/format all fine)
#   deepseek-v4-*        → HTTP 400 on any response_format
#   qwen3.7-max          → HTTP 400
#   minimax-m3           → accepts it, then returns <think> prose anyway
#
# Note: this endpoint sits behind Cloudflare, which 403s anonymous clients
# (error 1010). The backend sends an explicit User-Agent for that reason.
LLM_BASE_URL=https://opencode.ai/zen/go/v1
LLM_API_KEY=
LLM_MODEL=glm-5.2

# --- 공공데이터포털 (data.go.kr) ---
# The portal issues TWO keys: "Encoding" and "Decoding".
# USE THE DECODING KEY HERE (the raw one with +, /, = — no %2B).
# Passing the Encoding key makes UriComponentsBuilder double-encode
# '%' into '%25' and the API answers SERVICE_KEY_IS_NOT_REGISTERED_ERROR.
DATA_GO_KR_SERVICE_KEY=

# --- Naver Cloud Platform — Maps ---
# NCP console > Maps > Application. NOTE: the parameter is `ncpKeyId`,
# NOT the `ncpClientId` you will see in most blog posts (that is dead).
# Register http://localhost in the app's Web service URL allowlist.
VITE_NAVER_MAP_KEY_ID=
